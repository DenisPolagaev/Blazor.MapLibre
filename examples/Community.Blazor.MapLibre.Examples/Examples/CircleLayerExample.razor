@page "/examples/circle-layer"

@using Community.Blazor.MapLibre.Models.Feature
@using Community.Blazor.MapLibre.Models.Layers
@using Community.Blazor.MapLibre.Models.Sources

<ViewOnGitHub FilePath="examples/Community.Blazor.MapLibre.Examples/Examples/CircleLayerExample.razor"/>

<MapLibre @ref="_map"
          Options="_mapOptions"
          OnLoad="@OnMapLoad"
          Class="rounded-top"
          Height="600px">
</MapLibre>

@code {
    private MapLibre _map = new();

    private readonly MapOptions _mapOptions = new()
    {
        Style = ExampleMapStyles.OpenStreetMap,
        Center = new LngLat { Longitude = -94.58, Latitude = 39.1 },
        Zoom = 10,
    };

    private async Task OnMapLoad(EventArgs _)
    {
        await _map.AddSource("points", new GeoJsonSource
        {
            Data = new FeatureCollection
            {
                Features =
                [
                    new FeatureFeature
                    {
                        Geometry = new PointGeometry { Coordinates = [-94.62, 39.12] },
                        Properties = new Dictionary<string, object> { ["name"] = "A" },
                    },
                    new FeatureFeature
                    {
                        Geometry = new PointGeometry { Coordinates = [-94.55, 39.08] },
                        Properties = new Dictionary<string, object> { ["name"] = "B" },
                    },
                    new FeatureFeature
                    {
                        Geometry = new PointGeometry { Coordinates = [-94.5, 39.15] },
                        Properties = new Dictionary<string, object> { ["name"] = "C" },
                    },
                ],
            },
        });

        await _map.AddLayer(new CircleLayer
        {
            Id = "points-circle",
            Source = "points",
            Paint = new CircleLayerPaint
            {
                CircleColor = "#2980b9",
                CircleRadius = 10,
                CircleStrokeColor = "#ffffff",
                CircleStrokeWidth = 2,
            },
        });
    }
}
