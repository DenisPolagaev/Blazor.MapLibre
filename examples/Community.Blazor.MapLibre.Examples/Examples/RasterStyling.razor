@page "/examples/raster-styling"

<ViewOnGitHub FilePath="examples/Community.Blazor.MapLibre.Examples/Examples/RasterStyling.razor"/>

<MapLibre @ref="_map"
          Options="_mapOptions"
          OnLoad="@OnMapLoad"
          Class="rounded-top"
          Height="600px">
</MapLibre>

<div class="mt-2">
    <label>Contrast: @_contrast.ToString("0.0")</label>
    <input type="range" min="0" max="1" step="0.1" @bind="_contrast" @bind:event="oninput" @onchange="ApplyRasterStyle" />
</div>

@code {
    private MapLibre _map = new();
    private double _contrast = 0.2;

    private readonly MapOptions _mapOptions = new()
    {
        Style = ExampleMapStyles.OpenStreetMap,
        Center = new LngLat { Longitude = 2.35, Latitude = 48.85 },
        Zoom = 10,
    };

    private async Task OnMapLoad(EventArgs _)
    {
        await ApplyRasterStyle();
    }

    private async Task ApplyRasterStyle()
    {
        await _map.SetPaintProperty("osm", "raster-contrast", _contrast);
        await _map.SetPaintProperty("osm", "raster-saturation", 0.3);
    }
}
