@page "/examples/geogrid"

@using Community.Blazor.MapLibre.GeoGridPlugin
@using Community.Blazor.MapLibre.Models
@implements IAsyncDisposable

<link rel="stylesheet" href="_content/GeoGridPlugin/geogrid/geogrid.css" />

<ViewOnGitHub FilePath="examples/Community.Blazor.MapLibre.Examples/Examples/GeoGrid.razor" />

<p class="text-muted">
    Geographic graticule with coordinate labels, powered by
    <a href="https://github.com/falseinput/geogrid-maplibre-gl" target="_blank" rel="noopener">geogrid-maplibre-gl</a>.
</p>

<MapLibre @ref="_map"
          Options="_mapOptions"
          OnLoad="OnMapLoad"
          Class="rounded-top"
          Height="600px" />

<div class="form-check mt-3">
    <input class="form-check-input"
           type="checkbox"
           id="geoGridToggle"
           checked="@_geoGridVisible"
           @onchange="ToggleGeoGridAsync" />
    <label class="form-check-label" for="geoGridToggle">Show geographic grid</label>
</div>

@code {
    private MapLibre _map = new();
    private readonly GeoGridPlugin _geoGrid = new();
    private bool _geoGridVisible = true;
    private bool _pendingGeoGridAdd;

    private static readonly GeoGridOptions DefaultGeoGridOptions = new()
    {
        GridStyle = new GeoGridLineStyle
        {
            Color = "rgba(15, 23, 42, 0.25)",
            Width = 1,
        },
        LabelStyle = new GeoGridLabelStyle
        {
            Color = "rgba(15, 23, 42, 0.8)",
            FontSize = "12px",
        },
        ZoomLevelRange = [0, 14],
    };

    private readonly MapOptions _mapOptions = new()
    {
        Style = ExampleMapStyles.OpenStreetMap,
        Center = new LngLat(37.62, 55.75),
        Zoom = 4,
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _map.RegisterPlugin(_geoGrid);

            if (_pendingGeoGridAdd)
            {
                await AddGeoGridIfVisibleAsync();
            }
        }
    }

    private async Task OnMapLoad(EventArgs _)
    {
        if (!_geoGrid.IsInitialized)
        {
            _pendingGeoGridAdd = true;
            return;
        }

        await AddGeoGridIfVisibleAsync();
    }

    private async Task AddGeoGridIfVisibleAsync()
    {
        _pendingGeoGridAdd = false;

        if (!_geoGridVisible)
        {
            return;
        }

        await _geoGrid.AddGeoGridAsync(DefaultGeoGridOptions);
    }

    private async Task ToggleGeoGridAsync(ChangeEventArgs args)
    {
        _geoGridVisible = args.Value is bool visible && visible;

        if (_geoGridVisible)
        {
            await _geoGrid.ShowGeoGridAsync();
        }
        else
        {
            await _geoGrid.RemoveGeoGridAsync();
        }
    }

    public async ValueTask DisposeAsync() => await _geoGrid.DisposeAsync();
}
