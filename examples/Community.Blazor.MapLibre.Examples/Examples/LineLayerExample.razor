@page "/examples/line-layer"

@using Community.Blazor.MapLibre.Models.Feature
@using Community.Blazor.MapLibre.Models.Layers
@using Community.Blazor.MapLibre.Models.Sources

<ViewOnGitHub FilePath="examples/Community.Blazor.MapLibre.Examples/Examples/LineLayerExample.razor"/>

<MapLibre @ref="_map"
          Options="_mapOptions"
          OnLoad="@OnMapLoad"
          Class="rounded-top"
          Height="600px">
</MapLibre>

@code {
    private MapLibre _map = new();

    private readonly MapOptions _mapOptions = new()
    {
        Style = ExampleMapStyles.OpenStreetMap,
        Center = new LngLat { Longitude = -122.45, Latitude = 37.78 },
        Zoom = 12,
    };

    private async Task OnMapLoad(EventArgs _)
    {
        await _map.AddSource("route", new GeoJsonSource
        {
            Data = new FeatureFeature
            {
                Geometry = new LineGeometry
                {
                    Coordinates =
                    [
                        [-122.483696, 37.833818],
                        [-122.483482, 37.833174],
                        [-122.483396, 37.8327],
                        [-122.483568, 37.832056],
                        [-122.48404, 37.831141],
                        [-122.48404, 37.830497],
                        [-122.483482, 37.82992],
                        [-122.483568, 37.829476],
                        [-122.484118, 37.826938],
                    ],
                },
            },
        });

        await _map.AddLayer(new LineLayer
        {
            Id = "route-line",
            Source = "route",
            Paint = new LineLayerPaint
            {
                LineColor = "#e74c3c",
                LineWidth = 5,
                LineOpacity = 0.85,
            },
        });
    }
}
