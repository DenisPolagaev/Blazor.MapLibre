@page "/examples/map-events"
@implements IAsyncDisposable

@using Community.Blazor.MapLibre.Models.Event

<ViewOnGitHub FilePath="examples/Community.Blazor.MapLibre.Examples/Examples/MapEvents.razor"/>

<MapLibre @ref="_map"
          Options="_mapOptions"
          OnLoad="@OnMapLoad"
          Class="rounded-top"
          Height="600px">
</MapLibre>

<p class="mt-2">Last event: <strong>@_lastEvent</strong></p>
<button class="btn btn-sm btn-outline-secondary" @onclick="ToggleMoveListener">@(_moveListener is null ? "Subscribe moveend" : "Unsubscribe moveend")</button>

@code {
    private MapLibre _map = new();
    private Listener? _moveListener;
    private Listener? _idleListener;
    private string _lastEvent = "—";

    private readonly MapOptions _mapOptions = new()
    {
        Style = ExampleMapStyles.OpenStreetMap,
        Center = new LngLat { Longitude = 0, Latitude = 20 },
        Zoom = 2,
    };

    private async Task OnMapLoad(EventArgs _)
    {
        _idleListener = await _map.OnIdle(_ =>
        {
            _lastEvent = "idle";
            InvokeAsync(StateHasChanged);
        });

        _moveListener = await _map.OnMoveEnd(_ =>
        {
            _lastEvent = "moveend";
            InvokeAsync(StateHasChanged);
        });
    }

    private async Task ToggleMoveListener()
    {
        if (_moveListener is null)
        {
            _moveListener = await _map.OnMoveEnd(_ =>
            {
                _lastEvent = "moveend (re-subscribed)";
                InvokeAsync(StateHasChanged);
            });
        }
        else
        {
            await _moveListener.Remove();
            _moveListener = null;
            _lastEvent = "moveend listener removed";
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_moveListener is not null)
        {
            await _moveListener.Remove();
        }

        if (_idleListener is not null)
        {
            await _idleListener.Remove();
        }
    }
}
