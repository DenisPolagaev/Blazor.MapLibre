@page "/examples/hillshade-terrain"

@using Community.Blazor.MapLibre.Models.Layers
@using Community.Blazor.MapLibre.Models.Sources
@using Community.Blazor.MapLibre.Models.Style

<ViewOnGitHub FilePath="examples/Community.Blazor.MapLibre.Examples/Examples/HillshadeTerrain.razor"/>

<MapLibre @ref="_map"
          Options="_mapOptions"
          OnLoad="@OnMapLoad"
          Class="rounded-top"
          Height="600px">
</MapLibre>

@code {
    private MapLibre _map = new();

    private readonly MapOptions _mapOptions = new()
    {
        Style = ExampleMapStyles.OpenStreetMap,
        Center = new LngLat { Longitude = 11.5, Latitude = 47.3 },
        Zoom = 9,
        Pitch = 60,
    };

    private async Task OnMapLoad(EventArgs _)
    {
        await _map.AddSource("terrain", new RasterDEMTileSource
        {
            Url = "https://demotiles.maplibre.org/terrain-tiles/tiles.json",
            TileSize = 256,
        });

        await _map.SetTerrain(new TerrainSpecification
        {
            Source = "terrain",
            Exaggeration = 1.5,
        });

        await _map.AddLayer(new HillShadeLayer
        {
            Id = "hillshade",
            Source = "terrain",
            Paint = new HillShadeLayerPaint
            {
                HillshadeExaggeration = 0.8,
                HillshadeShadowColor = "#473B24",
            },
        });
    }
}
