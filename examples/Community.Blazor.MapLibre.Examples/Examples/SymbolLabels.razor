@page "/examples/symbol-labels"

@using Community.Blazor.MapLibre.Models.Feature
@using Community.Blazor.MapLibre.Models.Layers
@using Community.Blazor.MapLibre.Models.Sources

<ViewOnGitHub FilePath="examples/Community.Blazor.MapLibre.Examples/Examples/SymbolLabels.razor"/>

<MapLibre @ref="_map"
          Options="_mapOptions"
          OnLoad="@OnMapLoad"
          Class="rounded-top"
          Height="600px">
</MapLibre>

@code {
    private MapLibre _map = new();

    private readonly MapOptions _mapOptions = new()
    {
        Style = ExampleMapStyles.OpenStreetMap,
        Center = new LngLat { Longitude = 12.5, Latitude = 41.9 },
        Zoom = 5,
    };

    private async Task OnMapLoad(EventArgs _)
    {
        await _map.AddSource("cities", new GeoJsonSource
        {
            Data = new FeatureCollection
            {
                Features =
                [
                    new FeatureFeature
                    {
                        Geometry = new PointGeometry { Coordinates = [12.4964, 41.9028] },
                        Properties = new Dictionary<string, object> { ["name"] = "Rome" },
                    },
                    new FeatureFeature
                    {
                        Geometry = new PointGeometry { Coordinates = [2.3522, 48.8566] },
                        Properties = new Dictionary<string, object> { ["name"] = "Paris" },
                    },
                    new FeatureFeature
                    {
                        Geometry = new PointGeometry { Coordinates = [-3.7038, 40.4168] },
                        Properties = new Dictionary<string, object> { ["name"] = "Madrid" },
                    },
                ],
            },
        });

        await _map.AddLayer(new SymbolLayer
        {
            Id = "city-labels",
            Source = "cities",
            Layout = new SymbolLayerLayout
            {
                TextField = new System.Text.Json.Nodes.JsonArray { "get", "name" },
                TextFont = new[] { "Open Sans Regular" },
                TextSize = 14,
                TextOffset = new double[] { 0, 1.2 },
                TextAnchor = "top",
            },
            Paint = new SymbolLayerPaint
            {
                TextColor = "#2c3e50",
                TextHaloColor = "#ffffff",
                TextHaloWidth = 1.5,
            },
        });
    }
}
