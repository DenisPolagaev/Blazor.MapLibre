@page "/examples/sky-fog-terrain"

@using Community.Blazor.MapLibre.Models.Layers
@using Community.Blazor.MapLibre.Models.Sources
@using Community.Blazor.MapLibre.Models.Style

<ViewOnGitHub FilePath="examples/Community.Blazor.MapLibre.Examples/Examples/SkyFogTerrain.razor"/>

<p class="text-muted small mb-2">
    3D terrain with sky and fog (atmospheric haze at the horizon). Drag to rotate, right-click to pitch.
</p>

<div class="mb-2 d-flex flex-wrap gap-2">
    <button class="btn btn-sm btn-outline-primary" @onclick="() => ApplyPreset(SkyPreset.Clear)">Clear sky</button>
    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ApplyPreset(SkyPreset.Cloudy)">Cloudy / hazy</button>
    <button class="btn btn-sm btn-outline-warning" @onclick="() => ApplyPreset(SkyPreset.Sunset)">Sunset</button>
</div>

<div class="mb-2">
    <label class="form-label mb-0">Fog density: @_fogGroundBlend.ToString("0.00")</label>
    <input type="range" class="form-range" min="0" max="1" step="0.05" @bind="_fogGroundBlend" @bind:event="oninput" @onchange="ApplySkyAsync" />
</div>

<MapLibre @ref="_map"
          Options="_mapOptions"
          OnLoad="@OnMapLoad"
          Class="rounded-top"
          Height="600px">
</MapLibre>

@code {
    private MapLibre _map = new();
    private double _fogGroundBlend = 0.85;
    private SkyPreset _preset = SkyPreset.Cloudy;

    private readonly MapOptions _mapOptions = new()
    {
        Style = ExampleMapStyles.OpenStreetMap,
        Center = new LngLat { Longitude = 11.52, Latitude = 47.35 },
        Zoom = 11,
        Pitch = 72,
        Bearing = -25,
        MaxPitch = 85,
    };

    private enum SkyPreset
    {
        Clear,
        Cloudy,
        Sunset,
    }

    private async Task OnMapLoad(EventArgs _)
    {
        await _map.AddSource("terrain", new RasterDEMTileSource
        {
            Url = "https://demotiles.maplibre.org/terrain-tiles/tiles.json",
            TileSize = 256,
        });

        await _map.SetTerrain(new TerrainSpecification
        {
            Source = "terrain",
            Exaggeration = 1.4,
        });

        await ApplyPreset(SkyPreset.Cloudy);
    }

    private async Task ApplyPreset(SkyPreset preset)
    {
        _preset = preset;
        _fogGroundBlend = preset switch
        {
            SkyPreset.Clear => 0.45,
            SkyPreset.Cloudy => 0.88,
            SkyPreset.Sunset => 0.55,
            _ => _fogGroundBlend,
        };

        await ApplySkyAsync();
    }

    private async Task ApplySkyAsync()
    {
        var sky = _preset switch
        {
            SkyPreset.Clear => new SkySpecification
            {
                SkyColor = "#87CEEB",
                HorizonColor = "#E8F4FC",
                FogColor = "#D4E8F7",
                SkyHorizonBlend = 0.6,
                HorizonFogBlend = 0.3,
                FogGroundBlend = _fogGroundBlend,
                AtmosphereBlend = 0.5,
            },
            SkyPreset.Sunset => new SkySpecification
            {
                SkyColor = "#FF6347",
                HorizonColor = "#FF8C00",
                FogColor = "#FFDAB9",
                SkyHorizonBlend = 0.35,
                HorizonFogBlend = 0.55,
                FogGroundBlend = _fogGroundBlend,
                AtmosphereBlend = 0.75,
            },
            _ => new SkySpecification
            {
                SkyColor = "#B8D4E8",
                HorizonColor = "#F5F8FA",
                FogColor = "#FFFFFF",
                SkyHorizonBlend = 0.4,
                HorizonFogBlend = 0.85,
                FogGroundBlend = _fogGroundBlend,
                AtmosphereBlend = 0.65,
            },
        };

        await _map.SetSky(sky);
    }
}
