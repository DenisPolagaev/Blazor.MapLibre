@page "/examples/terra-draw"

@using Community.Blazor.MapLibre.TerraDrawPlugin
@using Community.Blazor.MapLibre.Models
@using Community.Blazor.MapLibre.Models.Control
@using System.Text.Json

<ViewOnGitHub FilePath="examples/Community.Blazor.MapLibre.Examples/Examples/TerraDraw.razor"/>

<MapLibre @ref="_map"
          Options="_mapOptions"
          OnLoad="OnMapLoad"
          Class="rounded-top"
          Height="600px">
</MapLibre>

<div class="d-flex flex-wrap gap-2 mt-3">
    <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleToolbar">
        @( _expanded ? "Collapse toolbar" : "Expand toolbar" )
    </button>
    <button class="btn btn-sm btn-outline-primary" @onclick="() => SetMode(TerradrawModes.Rectangle)">Rectangle</button>
    <button class="btn btn-sm btn-outline-primary" @onclick="() => SetMode(TerradrawModes.Circle)">Circle</button>
    <button class="btn btn-sm btn-outline-primary" @onclick="() => SetMode(TerradrawModes.Select)">Select</button>
    <button class="btn btn-sm btn-outline-secondary" @onclick="FinishGeometry">Finish</button>
    <button class="btn btn-sm btn-outline-danger" @onclick="StopDrawing">Stop</button>
</div>

<textarea class="form-control mt-3" rows="12" readonly>@_geoJsonSnapshot</textarea>

@code {
    private MapLibre _map = new();
    private TerraDrawPlugin _terraDraw = new();
    private Listener? _changeListener;
    private string _geoJsonSnapshot = "Draw on the map using the Terra Draw toolbar.";
    private bool _expanded = true;

    private readonly MapOptions _mapOptions = new()
    {
        Style = ExampleMapStyles.OpenStreetMap,
        Center = new LngLat(-73.99, 40.75),
        Zoom = 11,
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _map.RegisterPlugin(_terraDraw);
        }
    }

    private async Task OnMapLoad(EventArgs _)
    {
        await _terraDraw.AddDrawControlAsync(new TerradrawControlOptions
        {
            Open = true,
            Modes =
            [
                TerradrawModes.Point,
                TerradrawModes.LineString,
                TerradrawModes.Polygon,
                TerradrawModes.Rectangle,
                TerradrawModes.Circle,
                TerradrawModes.Select,
                TerradrawModes.Delete,
            ],
        }, ControlPosition.TopLeft);

        await _terraDraw.DisableMapZoomGesturesAsync();

        _changeListener = await _terraDraw.AddTerraDrawChangeListener<string>(OnGeometriesChanged, 150);
    }

    private void OnGeometriesChanged(string geoJson)
    {
        _geoJsonSnapshot = FormatJson(geoJson);
        StateHasChanged();
    }

    private async Task ToggleToolbar()
    {
        _expanded = !_expanded;
        await _terraDraw.SetControlExpandedAsync(_expanded);
    }

    private async Task SetMode(string mode) => await _terraDraw.SetModeAsync(mode);

    private async Task FinishGeometry() => await _terraDraw.FinishGeometryAsync();

    private async Task StopDrawing()
    {
        await _terraDraw.StopDrawingAsync();
        _geoJsonSnapshot = "Drawing stopped.";
    }

    private static string FormatJson(string json)
    {
        try
        {
            using var document = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(document, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }
}
