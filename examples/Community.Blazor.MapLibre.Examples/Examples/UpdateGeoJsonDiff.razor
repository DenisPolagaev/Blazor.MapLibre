@page "/examples/update-geojson-diff"
@implements IDisposable

@using Community.Blazor.MapLibre.Models.Feature
@using Community.Blazor.MapLibre.Models.Layers
@using Community.Blazor.MapLibre.Models.Sources

<ViewOnGitHub FilePath="examples/Community.Blazor.MapLibre.Examples/Examples/UpdateGeoJsonDiff.razor"/>

<MapLibre @ref="_map"
          Options="_options"
          OnLoad="HandleMapLoad"
          Class="rounded-top"
          Height="600px"/>

@code {
    private MapLibre _map = new();

    private readonly MapOptions _options = new()
    {
        Center = new LngLat { Longitude = -68.99, Latitude = 45.18 },
        Zoom = 5,
    };

    private int _tick;
    private readonly CancellationTokenSource _animationCts = new();

    private async Task HandleMapLoad(EventArgs args)
    {
        await _map.AddSource("rectangles", new GeoJsonSource
        {
            Data = new FeatureCollection
            {
                Features =
                [
                    CreateRectangle("rect-1", -69.5, 45.0, "#4e8752"),
                    CreateRectangle("rect-2", -68.2, 45.5, "#2563eb"),
                ],
            },
            GenerateId = false,
        });

        await _map.AddLayer(new FillLayer
        {
            Id = "rectangles-fill",
            Source = "rectangles",
            Paint = new FillLayerPaint
            {
                FillColor = "#4e8752",
                FillOpacity = 0.75,
            },
        });

        _ = AnimateAsync();
    }

    private async Task AnimateAsync()
    {
        while (!_animationCts.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(750, _animationCts.Token);
            }
            catch (OperationCanceledException)
            {
                break;
            }

            _tick++;

            var offset = (_tick % 10) * 0.05;
            await _map.UpdateSourceData("rectangles", new GeoJsonSourceDiff
            {
                Update =
                [
                    new GeoJsonFeatureDiff
                    {
                        Id = "rect-1",
                        AddOrUpdateProperties =
                        [
                            new GeoJsonPropertyUpdate { Key = "color", Value = _tick % 2 == 0 ? "#4e8752" : "#16a34a" },
                        ],
                        NewGeometry = ShiftRectangle(-69.5 + offset, 45.0),
                    },
                    new GeoJsonFeatureDiff
                    {
                        Id = "rect-2",
                        NewGeometry = ShiftRectangle(-68.2 - offset, 45.5),
                    },
                ],
            });
        }
    }

    private static FeatureFeature CreateRectangle(string id, double lng, double lat, string color) =>
        new()
        {
            Id = id,
            Properties = new Dictionary<string, object> { ["color"] = color },
            Geometry = ShiftRectangle(lng, lat),
        };

    private static PolygonGeometry ShiftRectangle(double lng, double lat) => new()
    {
        Coordinates =
        [
            [
                [lng, lat],
                [lng + 0.6, lat],
                [lng + 0.6, lat + 0.4],
                [lng, lat + 0.4],
                [lng, lat],
            ],
        ],
    };

    public void Dispose() => _animationCts.Cancel();
}
