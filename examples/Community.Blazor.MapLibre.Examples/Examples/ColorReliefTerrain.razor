@page "/examples/color-relief-terrain"

@using Community.Blazor.MapLibre.Models.Layers
@using Community.Blazor.MapLibre.Models.Sources
@using Community.Blazor.MapLibre.Models.Style

<ViewOnGitHub FilePath="examples/Community.Blazor.MapLibre.Examples/Examples/ColorReliefTerrain.razor"/>

<p class="text-muted small mb-2">
    Elevation color relief (<code>ColorReliefLayer</code>) with 3D terrain and sky — verifies new layer type and DEM pipeline.
</p>

<MapLibre @ref="_map"
          Options="_mapOptions"
          OnLoad="@OnMapLoad"
          Class="rounded-top"
          Height="600px">
</MapLibre>

@code {
    private MapLibre _map = new();

    private readonly MapOptions _mapOptions = new()
    {
        Style = ExampleMapStyles.OpenStreetMap,
        Center = new LngLat { Longitude = -119.57, Latitude = 37.74 },
        Zoom = 9,
        Pitch = 55,
        Bearing = 20,
    };

    private async Task OnMapLoad(EventArgs _)
    {
        await _map.AddSource("terrain", new RasterDEMTileSource
        {
            Url = "https://demotiles.maplibre.org/terrain-tiles/tiles.json",
            TileSize = 256,
        });

        await _map.SetTerrain(new TerrainSpecification
        {
            Source = "terrain",
            Exaggeration = 1.2,
        });

        await _map.AddLayer(new ColorReliefLayer
        {
            Id = "elevation-relief",
            Source = "terrain",
            Paint = new ColorReliefLayerPaint
            {
                ColorReliefOpacity = 0.85,
            },
        });

        await _map.SetSky(new SkySpecification
        {
            SkyColor = "#91C8F0",
            HorizonColor = "#E6F2FA",
            FogColor = "#E8F0F8",
            FogGroundBlend = 0.7,
            AtmosphereBlend = 0.4,
        });
    }
}
