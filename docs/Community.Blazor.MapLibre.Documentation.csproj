<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <IsPackable>false</IsPackable>
        <RootNamespace>Community.Blazor.MapLibre</RootNamespace>
    </PropertyGroup>

    <Target Name="ClearBuildArtifacts" AfterTargets="Clean">
        <RemoveDir Directories="dist"/>
        <RemoveDir Directories="api"/>
        <RemoveDir Directories="obj"/>
        <RemoveDir Directories="bin"/>
    </Target>

    <ItemGroup>
        <DocContent Include="content/**/*.md;content/**/*.yml;content/**/.order;index.md;toc.yml;docfx.json" />
    </ItemGroup>

    <Target Name="IntallTools" AfterTargets="Build">
        <Exec Command="dotnet tool restore"/>
    </Target>

    <Target Name="BuildTableOfContents" AfterTargets="Build">
        <Exec Command="dotnet DocFxTocGenerator --docfolder ./content/getting-started --outfolder ./content/getting-started --sequence --override"/>
        <Exec Command="dotnet DocFxTocGenerator --docfolder ./content/plugins --outfolder ./content/plugins --sequence --override -m 2"/>
        <Exec Command="dotnet DocFxTocGenerator --docfolder ./content/examples --outfolder ./content/examples --sequence --override"/>
        <Exec Command="dotnet DocFxTocGenerator --docfolder ./content/api --outfolder ./content/api --sequence --override -m 2"/>
    </Target>

    <Target Name="BuildSite" AfterTargets="BuildTableOfContents">
        <Exec Command="dotnet docfx docfx.json --output $(OutputPath)/dist"/>
    </Target>

    <!-- Rebuild docs when only markdown changes and the user runs the docs project. -->
    <Target Name="PrepareDocSiteForRun" BeforeTargets="Run" DependsOnTargets="BuildTableOfContents;BuildSite"/>

    <Target Name="PublishExampleComponentsToDocsSite" AfterTargets="BuildSite">
        <PropertyGroup>
            <ExamplesPublishDir>$(MSBuildProjectDirectory)\obj\examples-publish\</ExamplesPublishDir>
        </PropertyGroup>

        <Message Text="Publishing Blazor examples into the documentation site..." Importance="high" />
        <RemoveDir Directories="$(ExamplesPublishDir)" />
        <Exec Command="dotnet publish $(MSBuildThisFileDirectory)..\examples\Community.Blazor.MapLibre.Examples\Community.Blazor.MapLibre.Examples.csproj -c $(Configuration) -o $(ExamplesPublishDir)" />

        <!-- Remove previously copied example assets so old WASM bundles cannot linger in dist. -->
        <RemoveDir Directories="$(OutputPath)\dist\_framework" />
        <RemoveDir Directories="$(OutputPath)\dist\_content" />
        <RemoveDir Directories="$(OutputPath)\dist\css" />
        <RemoveDir Directories="$(OutputPath)\dist\data" />
        <ItemGroup>
            <StaleExampleRootAssets Include="$(OutputPath)\dist\*.wasm" />
            <StaleExampleRootAssets Include="$(OutputPath)\dist\*.wasm.br" />
            <StaleExampleRootAssets Include="$(OutputPath)\dist\*.wasm.gz" />
            <StaleExampleRootAssets Include="$(OutputPath)\dist\dotnet.js" />
            <StaleExampleRootAssets Include="$(OutputPath)\dist\blazor.webassembly.js" />
            <StaleExampleRootAssets Include="$(OutputPath)\dist\blazor.webassembly.js.br" />
            <StaleExampleRootAssets Include="$(OutputPath)\dist\blazor.webassembly.js.gz" />
            <StaleExampleRootAssets Include="$(OutputPath)\dist\Community.Blazor.MapLibre.Examples.styles.css" />
            <StaleExampleRootAssets Include="$(OutputPath)\dist\Community.Blazor.MapLibre.Examples.styles.css.*" />
            <StaleExampleRootAssets Include="$(OutputPath)\dist\Community.Blazor.MapLibre.Examples.runtimeconfig.json" />
            <StaleExampleRootAssets Include="$(OutputPath)\dist\Community.Blazor.MapLibre.Examples.staticwebassets.endpoints.json" />
        </ItemGroup>
        <Delete Files="@(StaleExampleRootAssets)" />

        <ItemGroup>
            <PublishedFrameworkFiles Include="$(ExamplesPublishDir)_framework\**\*.*" />
            <PublishedContentFiles Include="$(ExamplesPublishDir)_content\**\*.*" />
            <PublishedCssFiles Include="$(ExamplesPublishDir)css\**\*.*" />
            <PublishedDataFiles Include="$(ExamplesPublishDir)data\**\*.*" />
        </ItemGroup>
        <Copy SourceFiles="@(PublishedFrameworkFiles)"
              DestinationFolder="$(OutputPath)\dist\_framework\%(PublishedFrameworkFiles.RecursiveDir)"
              SkipUnchangedFiles="false" />
        <Copy SourceFiles="@(PublishedContentFiles)"
              DestinationFolder="$(OutputPath)\dist\_content\%(PublishedContentFiles.RecursiveDir)"
              SkipUnchangedFiles="false" />
        <Copy SourceFiles="@(PublishedCssFiles)"
              DestinationFolder="$(OutputPath)\dist\css\%(PublishedCssFiles.RecursiveDir)"
              SkipUnchangedFiles="false" />
        <Copy SourceFiles="@(PublishedDataFiles)"
              DestinationFolder="$(OutputPath)\dist\data\%(PublishedDataFiles.RecursiveDir)"
              SkipUnchangedFiles="false" />
        <Copy SourceFiles="$(ExamplesPublishDir)Community.Blazor.MapLibre.Examples.styles.css"
              DestinationFolder="$(OutputPath)\dist"
              SkipUnchangedFiles="false" />
        <Copy SourceFiles="$(ExamplesPublishDir)Community.Blazor.MapLibre.Examples.styles.css.br"
              DestinationFolder="$(OutputPath)\dist"
              SkipUnchangedFiles="false"
              Condition="Exists('$(ExamplesPublishDir)Community.Blazor.MapLibre.Examples.styles.css.br')" />
        <Copy SourceFiles="$(ExamplesPublishDir)Community.Blazor.MapLibre.Examples.styles.css.gz"
              DestinationFolder="$(OutputPath)\dist"
              SkipUnchangedFiles="false"
              Condition="Exists('$(ExamplesPublishDir)Community.Blazor.MapLibre.Examples.styles.css.gz')" />
    </Target>

</Project>